
/**
 * Definition for singly-linked list.
 * struct ListNode {
 *     int val;
 *     ListNode *next;
 *     ListNode(int x) : val(x), next(nullptr) {}
 * };
 */

class Solution {
public:
    ListNode* reverseKGroup(ListNode* head, int k) {
        // 1. Check if there are k nodes to reverse
        ListNode* curr = head;
        for (int i = 0; i < k; ++i) {
            if (!curr) return head; // Fewer than k nodes, keep as is
            curr = curr->next;
        }

        // 2. Reverse the current k nodes
        ListNode* prev = nullptr;
        ListNode* nextNode = nullptr;
        curr = head;
        for (int i = 0; i < k; ++i) {
            nextNode = curr->next;
            curr->next = prev;
            prev = curr;
            curr = nextNode;
        }

        // 3. Connect reversed head to the next processed group
        // 'head' is now the tail of this reversed segment
        if (nextNode) {
            head->next = reverseKGroup(nextNode, k);
        }

        // 'prev' is now the new head of this reversed segment
        return prev;
    }
};
