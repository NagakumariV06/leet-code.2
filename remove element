class Solution {
public:
    int removeElement(vector<int>& nums, int val) {
        int k = 0; // Index for the next element not equal to val

        for (int i = 0; i < nums.size(); i++) {
            // If current element is not the one to remove
            if (nums[i] != val) {
                nums[k] = nums[i];
                k++;
            }
        }

        return k;
    }
};
