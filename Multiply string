#include <string>
#include <vector>

using namespace std;

class Solution {
public:
    string multiply(string num1, string num2) {
        // Edge case: if either number is "0", the product is "0"
        if (num1 == "0" || num2 == "0") return "0";
        
        int m = num1.length();
        int n = num2.length();
        
        // The max possible length of the product of strings with length m and n is m + n
        vector<int> result(m + n, 0);
        
        // Loop from right to left
        for (int i = m - 1; i >= 0; --i) {
            for (int j = n - 1; j >= 0; --j) {
                // Multiply single digits
                int mul = (num1[i] - '0') * (num2[j] - '0');
                
                // Position indices in the result array
                int p1 = i + j;
                int p2 = i + j + 1;
                
                // Add the product to the value currently at p2
                int sum = mul + result[p2];
                
                result[p2] = sum % 10;
                result[p1] += sum / 10; // Carry over to p1
            }
        }
        
        // Convert the vector of digits back to a string
        string product_str = "";
        int start_index = 0;
        
        // Skip leading zeros
        while (start_index < result.size() && result[start_index] == 0) {
            start_index++;
        }
        
        // Append the remaining digits to the string
        while (start_index < result.size()) {
            product_str += to_string(result[start_index++]);
        }
        
        return product_str;
    }
};
