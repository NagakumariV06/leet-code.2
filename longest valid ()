class Solution {
public:
    int longestValidParentheses(string s) {
        stack<int> st;
        st.push(-1); // Base for calculations
        int max_len = 0;

        for (int i = 0; i < s.length(); i++) {
            if (s[i] == '(') {
                st.push(i);
            } else {
                st.pop();
                if (st.empty()) {
                    // Current ')' is a boundary for the next valid string
                    st.push(i);
                } else {
                    // Calculate length between current ')' and the last unmatched '(' or boundary
                    max_len = max(max_len, i - st.top());
                }
            }
        }

        return max_len;
    }
};
