class Solution {
public:
    bool isValidSudoku(vector<vector<char>>& board) {
        // Use arrays of size 9x9 to track digits 1-9 for rows, cols, and boxes
        bool rows[9][9] = {false};
        bool cols[9][9] = {false};
        bool boxes[9][9] = {false};

        for (int r = 0; r < 9; ++r) {
            for (int c = 0; c < 9; ++c) {
                if (board[r][c] == '.') continue;

                int num = board[r][c] - '1'; // Convert '1'-'9' to index 0-8
                int box_idx = (r / 3) * 3 + (c / 3);

                // Check if the number has already appeared in this row, col, or box
                if (rows[r][num] || cols[c][num] || boxes[box_idx][num]) {
                    return false;
                }

                // Mark the number as seen
                rows[r][num] = true;
                cols[c][num] = true;
                boxes[box_idx][num] = true;
            }
        }

        return true;
    }
};
